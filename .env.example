# LLM Provider: "ollama" | "gemini" | "openrouter"
LLM_PROVIDER=ollama
FALLBACK_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Gemini API
GEMINI_API_KEY=your-api-key
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter API
OPENROUTER_API_KEY=your-api-key
OPENROUTER_MODEL=qwen/qwen3-8b

# Translation Settings
TRANSLATION_TEMPERATURE=0.3
TRANSLATION_MAX_TOKENS=4096
CHUNK_SIZE=1500
CHUNK_OVERLAP=100
REVIEW_THRESHOLD=0.7
MAX_RETRIES=2
ENABLE_REVIEW=false
ENABLE_SUMMARY=false

# Novel Share Directory (optional)
# When set, input is read from {NOVEL_SHARE_DIR}/{novel}/chapter_{number}.txt
# and output is written to {NOVEL_SHARE_DIR}/output/{novel}/
# NOVEL_SHARE_DIR=../share
